<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.SplitPane?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.till.controller.MainController"
            fx:id="rootPane">

    <!-- Top header -->
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 12;">
            <Label text="Till POS System"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <!-- Main content: products | cart -->
    <center>
        <SplitPane fx:id="splitPane"
                   dividerPositions="0.55"
                   orientation="HORIZONTAL"
                   VBox.vgrow="ALWAYS" />
    </center>

    <!-- Bottom: payment / status area -->
    <bottom>
        <VBox spacing="12" style="-fx-padding: 12; -fx-background-color: #f5f5f5;">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Cash given:" />
                <TextField fx:id="cashField" promptText="Enter amount" prefWidth="180" />

                <Button text="Pay with Cash" onAction="#handleCashPayment"
                        prefWidth="160" prefHeight="45"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />

                <Button text="Pay with Card" onAction="#handleCardPayment"
                        prefWidth="160" prefHeight="45"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
                <Button fx:id="adminButton" text="Admin (Stock)" onAction="#openAdminStock"/>

                <Button text="Logout" onAction="#handleLogout" prefWidth="120" prefHeight="40"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
            </HBox>

            <Label fx:id="resultLabel" text="" style="-fx-font-size: 16; -fx-font-weight: bold;" />
            <Label text="Ready" style="-fx-font-style: italic; -fx-text-fill: #555;" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" />
        </VBox>
    </bottom>

</BorderPane>