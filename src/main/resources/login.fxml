<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.till.controller.LoginController"
      alignment="CENTER" spacing="20" style="-fx-padding: 40; -fx-background-color: #f0f2f5;">

    <Label text="Till POS Login" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Manager Access Only" style="-fx-font-size: 16; -fx-text-fill: #7f8c8d;"/>

    <VBox spacing="15" alignment="CENTER" maxWidth="300">
        <Label text="Password:" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" promptText="Enter manager password" prefWidth="300"/>

        <Button fx:id="loginButton" text="Login as Manager" prefWidth="300" prefHeight="45"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16;"
                onAction="#handleLogin"/>

        <Button text="Login as Cashier (No Password)" prefWidth="300" prefHeight="45"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;"
                onAction="#handleCashierLogin"/>
    </VBox>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 14; -fx-font-weight: bold;"/>
</VBox>