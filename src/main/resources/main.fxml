<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.control.SplitPane?>
<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.till.controller.MainController"
            fx:id="rootPane">


    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 12;">
            <Label text="Till POS System"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"/>
        </VBox>
    </top>


    <center>
        <SplitPane fx:id="splitPane" dividerPositions="0.55" orientation="HORIZONTAL" />
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 8; -fx-background-color: #ecf0f1;">

            <Label text="Ready" style="-fx-font-style: italic;"/>
        </HBox>
    </bottom>

</BorderPane>